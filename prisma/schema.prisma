// =====================================================================
// sra-checker — Prisma schema
// ---------------------------------------------------------------------
// SQLite-based store. Auth-modellen volgen het BetterAuth core schema.
// Gebruikers uploaden hun eigen SRA-checklist + jaarrekening; alle
// data is per-user gescoped.
// =====================================================================
 
generator client {
  provider = "prisma-client-js"
}
 
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}
 
// ----------------------------- Auth -----------------------------------
 
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
 
  sessions   Session[]
  accounts   Account[]
  documents  Document[]
  checklists Checklist[]
}
 
model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@index([userId])
}
 
model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  password              String?
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@index([userId])
}
 
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
 
// ------------------------ Domain — checklist --------------------------
 
/// Een door de gebruiker geüploade SRA-checklist (.xlsm).
/// Bevat metadata over welke sheets erin zitten en hoeveel i+d-checks
/// per sheet, zodat de UI een rijke selector kan tonen.
model Checklist {
  id          String   @id @default(cuid())
  userId      String
  name        String   // bv. "SRA-checklist 2024"
  filename    String
  storagePath String
  /// JSON-array: [{ "name": "Grondslagen...", "idCount": 39 }, ...]
  sheets      String
  createdAt   DateTime @default(now())
 
  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ChecklistItem[]
 
  @@index([userId])
}
 
/// Eén controlepunt uit één sheet van een Checklist.
model ChecklistItem {
  id          String   @id @default(cuid())
  checklistId String
  sheet       String
  ordering    Int
  description String
  source      String?
 
  appliesGroot  Boolean @default(false)
  appliesMidden Boolean @default(false)
  appliesKlein  Boolean @default(false)
 
  checklist Checklist     @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  results   CheckResult[]
 
  @@index([checklistId, sheet, ordering])
}
 
// ------------------------ Domain — document --------------------------
 
/// Een door de gebruiker geüploade jaarrekening (PDF).
model Document {
  id          String   @id @default(cuid())
  userId      String
  filename    String
  storagePath String
  pageCount   Int
  createdAt   DateTime @default(now())
 
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks  DocumentChunk[]
  results CheckResult[]
 
  @@index([userId])
}
 
model DocumentChunk {
  id         String  @id @default(cuid())
  documentId String
  page       Int
  content    String
  embedding  String?
 
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
 
  @@index([documentId])
}
 
model CheckResult {
  id              String   @id @default(cuid())
  documentId      String
  checklistItemId String
 
  status        String
  pageReference Int?
  citation      String?
  reasoning     String
  modelUsed     String
  createdAt     DateTime @default(now())
 
  document      Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  checklistItem ChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
 
  @@unique([documentId, checklistItemId])
  @@index([documentId])
}
 